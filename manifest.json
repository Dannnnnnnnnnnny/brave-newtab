{
  "manifest_version": 3,
  "name": "New Tab",
  "version": "1.0.0",
  "description": "Minimal new tab page",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage", "history"],
  "web_accessible_resources": [{
    "resources": ["icons/*.svg"],
    "matches": ["<all_urls>"]
  }]
}
