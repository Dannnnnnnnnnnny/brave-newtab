{
  "manifest_version": 3,
  "name": "New Tab",
  "version": "1.0.0",
  "description": "Minimal new tab page",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage", "history"],
  "web_accessible_resources": [{
    "resources": ["icons/*.svg", "backgrounds/*.jpg"],
    "matches": ["<all_urls>"]
  }]
}
